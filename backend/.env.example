NODE_ENV=development
PORT=5000

# Comma-separated allowed frontend origins.
# Example for GitHub Pages: https://<username>.github.io
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=coding_tracker
DB_SSL=false

# Optional Clever Cloud vars (if set, app can auto-read these)
# MYSQL_ADDON_HOST=
# MYSQL_ADDON_DB=
# MYSQL_ADDON_USER=
# MYSQL_ADDON_PORT=3306
# MYSQL_ADDON_PASSWORD=
# MYSQL_ADDON_URI=

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
